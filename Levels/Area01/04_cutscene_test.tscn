npc_info = ExtResource("6_86h4m")

[node name="DialogText3" type="Node" parent="AreaTrigger/DialogInteraction" unique_id=15568015]
script = ExtResource("9_bchre")
text = "
Indeed, there is power within you..."
npc_info = ExtResource("6_86h4m")

[node name="DialogText4" type="Node" parent="AreaTrigger/DialogInteraction" unique_id=232324589]
script = ExtResource("9_bchre")
text = "
Have you taken the oath of the warrior?"
npc_info = ExtResource("6_86h4m")

[node name="DialogText5" type="Node" parent="AreaTrigger/DialogInteraction" unique_id=42446444]
script = ExtResource("9_bchre")
text = "I have only begun my training. I fear I am not ready to be tested.
What must I do to prove my readiness?"
npc_info = ExtResource("12_hvxrb")

[node name="DialogText6" type="Node" parent="AreaTrigger/DialogInteraction" unique_id=480734920]
script = ExtResource("9_bchre")
text = "Perhaps, if you could send this pot over
those hills. Such a feat would show that
you are most worthy."
npc_info = ExtResource("6_86h4m")

[node name="DialogText7" type="Node" parent="AreaTrigger/DialogInteraction" unique_id=1205293026]
script = ExtResource("9_bchre")
text = "
I'll try..."
npc_info = ExtResource("12_hvxrb")

